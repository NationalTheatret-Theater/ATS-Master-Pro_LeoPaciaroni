rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global Helpers
    function isSignedIn() {
      return true; // Simplified for open access mode
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidClient(data) {
      return data.keys().hasAll(['fullName', 'email', 'ownerId']) 
        && data.fullName is string && data.fullName.size() <= 200
        && data.email is string && data.email.size() <= 200
        && data.ownerId is string; // Allow any string ID in open mode
    }

    function isValidResume(data) {
      return data.keys().hasAll(['clientId', 'rawText', 'ownerId'])
        && data.clientId is string && data.clientId.size() <= 128
        && data.rawText is string && data.rawText.size() <= 1000000
        && data.ownerId is string;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['clientId', 'resumeId', 'scores', 'ownerId'])
        && data.scores is map
        && data.ownerId is string;
    }

    // Paths
    match /clients/{clientId} {
      allow read, write: if true; // Truly open access for troubleshooting phase

      match /resumes/{resumeId} {
        allow read, write: if true;
      }

      match /jobs/{jobId} {
        allow read, write: if true;
      }

      match /analyses/{analysisId} {
        allow read, write: if true;
      }
    }
  }
}
